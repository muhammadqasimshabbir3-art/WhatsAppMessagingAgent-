# WhatsApp Messaging Agent — copy to .env and fill in values

# Required: Groq API for message analysis and reply generation
GROQ_API_KEY=

# Persistent Chrome profile for WhatsApp Web (./start.sh browser — scan QR once, then reused)
BROWSER_PROFILE_PATH=./data/chrome_profile
BROWSER_CHANNEL=chrome
# Agent automation uses headless after profile is saved; first QR scan uses visible Chrome
BROWSER_HEADLESS=true
KEEP_BROWSER_OPEN=true
BROWSER_LOGIN_TIMEOUT_MS=120000
BROWSER_DEBUG_PORT=9222
BROWSER_API_PORT=2025

# Legacy cookie export (optional; profile folder is preferred)
WHATSAPP_SESSION_PATH=./data/whatsapp_session.json
REPLY_HISTORY_PATH=./data/reply_history.json

# Inbox scan and replies
MAX_CHATS_TO_PROCESS=5
MAX_MESSAGES_PER_CHAT=10
MAX_REPLIES_PER_RUN=5
REPLY_PERSONALITY=friendly
REPLY_ONLY_UNREAD_CHATS=true
CONTACT_FILTER=
ENABLE_MESSAGE_REPLIES=false

# Reply category toggles
REPLY_TO_POSITIVE=true
REPLY_TO_NEGATIVE=true
REPLY_TO_NEUTRAL=true
REPLY_TO_QUESTIONS=true
REPLY_TO_SUGGESTIONS=true
REPLY_TO_SPAM=false

# Email reports via Gmail SMTP (app password — not used for browser login)
EMAIL_REPORTS=true
GMAIL_SMTP_USER=
GMAIL_APP_PASSWORD=
GMAIL_DEFAULT_RECIPIENT=

# Local dev ports
LANGGRAPH_PORT=2024
FRONTEND_PORT=5173
VITE_LANGGRAPH_API_URL=http://127.0.0.1:2024
VITE_BROWSER_API_URL=http://127.0.0.1:2025
