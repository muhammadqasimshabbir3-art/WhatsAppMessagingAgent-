# Runtime secrets / env for the Northflank combined service
# Add these under Service → Environment / Secrets (not committed).

GROQ_API_KEY=
PORT=8000
BROWSER_HEADLESS=true
BROWSER_PROFILE_PATH=/data/chrome_profile
KEEP_BROWSER_OPEN=true
ENABLE_MESSAGE_REPLIES=false
MAX_CHATS_TO_PROCESS=5
MAX_MESSAGES_PER_CHAT=10
MAX_REPLIES_PER_RUN=5
REPLY_ONLY_UNREAD_CHATS=true

# Allow the Vercel UI origin (comma-separated if LangGraph needs CORS overrides)
# CORS_ALLOW_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Optional email reports
EMAIL_REPORTS=false
GMAIL_SMTP_USER=
GMAIL_APP_PASSWORD=
GMAIL_DEFAULT_RECIPIENT=